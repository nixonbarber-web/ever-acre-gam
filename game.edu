<!DOCTYPE html>
<html>
<head>
<style>
  body { background: #e0f7fa; font-family: 'Arial', sans-serif; overflow: hidden; margin: 0; }
  #game-world { width: 100vw; height: 100vh; background: url('https://img.freepik.com'); background-size: cover; position: relative; }
  
  /* Draggable Items */
  .item { width: 80px; position: absolute; cursor: grab; transition: transform 0.1s; user-select: none; }
  .item:active { cursor: grabbing; transform: scale(1.1); z-index: 100; }

  /* UI Menu */
  #catalog { position: fixed; bottom: 0; width: 100%; height: 120px; background: rgba(255,255,255,0.8); display: flex; align-items: center; padding: 10px; border-top: 5px solid #ffccbc; gap: 20px; overflow-x: auto; }
  .spawn-btn { width: 60px; height: 60px; background: #fff; border-radius: 10px; border: 2px solid #ff8a65; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 30px; }
</style>
</head>
<body>

<div id="game-world">
  <h2 style="text-align: center; color: white; text-shadow: 2px 2px #ff8a65;">Ever-Acre Grove: Web Edition</h2>
</div>

<div id="catalog">
  <div class="spawn-btn" onclick="spawn('🐱')">🐱</div> <!-- Character -->
  <div class="spawn-btn" onclick="spawn('🌳')">🌳</div> <!-- Tree -->
  <div class="spawn-btn" onclick="spawn('🏠')">🏠</div> <!-- House -->
  <div class="spawn-btn" onclick="spawn('🛋️')">🛋️</div> <!-- Couch -->
  <div class="spawn-btn" onclick="spawn('🍎')">🍎</div> <!-- Food -->
</div>

<script>
  function spawn(emoji) {
    const el = document.createElement('div');
    el.className = 'item';
    el.innerHTML = `<span style="font-size: 60px;">${emoji}</span>`;
    el.style.left = '50%';
    el.style.top = '50%';
    document.getElementById('game-world').appendChild(el);
    makeDraggable(el);
  }

  function makeDraggable(el) {
    let pos1 = 0, pos2 = 0, pos3 = 0, pos4 = 0;
    el.onmousedown = dragMouseDown;

    function dragMouseDown(e) {
      e.preventDefault();
      pos3 = e.clientX;
      pos4 = e.clientY;
      document.onmouseup = closeDragElement;
      document.onmousemove = elementDrag;
    }

    function elementDrag(e) {
      e.preventDefault();
      pos1 = pos3 - e.clientX;
      pos2 = pos4 - e.clientY;
      pos3 = e.clientX;
      pos4 = e.clientY;
      el.style.top = (el.offsetTop - pos2) + "px";
      el.style.left = (el.offsetLeft - pos1) + "px";
    }

    function closeDragElement() {
      document.onmouseup = null;
      document.onmousemove = null;
    }
  }
</script>
</body>
</html>
